# ══════════════════════════════════════════════════════════════
#  FALLBACK .env — backup/fallback.env.example
#
#  Use this if the primary .env is lost or corrupted.
#  Replace ALL <placeholder> values before use.
#  Copy to backend/.env: cp backup/fallback.env.example ../.env
# ══════════════════════════════════════════════════════════════

PORT=5000
NODE_ENV=development

MONGO_URI_DEV=mongodb+srv://<dev_user>:<dev_password>@dev-cluster.xxxxx.mongodb.net/sih25031_dev?retryWrites=true&w=majority
MONGO_URI_PROD=mongodb+srv://<prod_user>:<prod_password>@prod-cluster.yyyyy.mongodb.net/sih25031_prod?retryWrites=true&w=majority
MONGO_URI_BACKUP=mongodb+srv://<backup_user>:<backup_password>@backup-cluster.zzzzz.mongodb.net/sih25031_backup?retryWrites=true&w=majority

AI_SERVICE_URL=http://localhost:5001

AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=<account_name>;AccountKey=<account_key>;EndpointSuffix=core.windows.net
AZURE_CONTAINER_NAME=civic-issue-uploads
AZURE_CDN_BASE_URL=https://<cdn-endpoint>.azureedge.net

FRONTEND_URL=http://localhost:3000

JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
